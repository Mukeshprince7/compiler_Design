  decl n
  decl result
  decl i
  t0 = 5
  n = t0
  t1 = 1
  result = t1
  t2 = 1
  i = t2
L0:
  t3 = i <= n
  if_false t3 goto L1
  t4 = result * i
  result = t4
  t5 = 1
  t6 = i + t5
  i = t6
  goto L0
L1:
  print result
  decl x
  t7 = 10
  x = t7
  t8 = 5
  t9 = x > t8
  if_false t9 goto L2
  print x
  goto L3
L2:
  t10 = 1
  t11 = x + t10
  x = t11
  print x
L3:

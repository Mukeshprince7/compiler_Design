// Computes factorial of 5 using while loop

int n;
int result;
int i;

n = 5;
result = 1;
i = 1;

while (i <= n) begin
    result = result * i;
    i = i + 1;
end

print(result);

// If-else demo
int x;
x = 10;

if (x > 5) begin
    print(x);
end else begin
    x = x + 1;
    print(x);
end
